{
  "name": "claude-toolshed",
  "owner": {
    "name": "Eigenwise",
    "email": "kenny@eigenwise.io"
  },
  "description": "Eigenwise's toolshed of Claude Code plugins.",
  "version": "1.1.0",
  "plugins": [
    {
      "name": "codebase-mapper",
      "source": "./plugins/codebase-mapper",
      "description": "A self-maintaining codebase map: atomic docs that Claude re-injects on every prompt and keeps in sync as the code changes. Any stack; greenfield or existing.",
      "version": "2.2.0",
      "author": {
        "name": "Eigenwise"
      },
      "homepage": "https://github.com/Eigenwise/claude-toolshed/tree/main/plugins/codebase-mapper",
      "repository": "https://github.com/Eigenwise/claude-toolshed",
      "license": "MIT",
      "category": "documentation",
      "keywords": [
        "documentation",
        "codebase",
        "mapping",
        "context",
        "grounding",
        "onboarding",
        "architecture",
        "self-maintaining"
      ]
    },
    {
      "name": "live-rules",
      "source": "./plugins/live-rules",
      "description": "Project rules in a Markdown file that Claude re-injects right when they apply: every prompt, or just before it edits a matching file. Edits apply on the next prompt, no restart.",
      "version": "2.0.0",
      "author": {
        "name": "Eigenwise"
      },
      "homepage": "https://github.com/Eigenwise/claude-toolshed/tree/main/plugins/live-rules",
      "repository": "https://github.com/Eigenwise/claude-toolshed",
      "license": "MIT",
      "category": "workflow",
      "keywords": [
        "rules",
        "context",
        "hooks",
        "guardrails",
        "conventions",
        "standards",
        "runtime",
        "developer-experience"
      ]
    }
  ]
}
