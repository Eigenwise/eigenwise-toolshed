{
  "uid": "claude-code-usage",
  "title": "Claude Code Usage",
  "tags": [
    "claude-code",
    "workbench",
    "tokens"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "editable": true,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "project",
        "label": "Project",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "query": "label_values(claude_code_token_usage_tokens_total, project_id)",
          "refId": "project"
        },
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Total tokens",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(claude_code_token_usage_tokens_total{project_id=~\"$project\"}[$__range]))"
        }
      ]
    },
    {
      "id": 2,
      "title": "Input tokens",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(claude_code_token_usage_tokens_total{type=\"input\",project_id=~\"$project\"}[$__range]))"
        }
      ]
    },
    {
      "id": 3,
      "title": "Output tokens",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "purple"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(claude_code_token_usage_tokens_total{type=\"output\",project_id=~\"$project\"}[$__range]))"
        }
      ]
    },
    {
      "id": 4,
      "title": "Cost (USD)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "color": {
            "mode": "fixed",
            "fixedColor": "orange"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(claude_code_cost_usage_USD_total{project_id=~\"$project\"}[$__range]))"
        }
      ]
    },
    {
      "id": 5,
      "title": "Tokens over time, by type",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "stacking": {
              "mode": "normal"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "sum"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "legendFormat": "{{type}}",
          "expr": "sum by (type) (increase(claude_code_token_usage_tokens_total{project_id=~\"$project\"}[$__rate_interval]))"
        }
      ]
    },
    {
      "id": 6,
      "title": "Tokens over time, by model",
      "description": "Full input context volume by resolved gateway model. Adding per-type vectors would drop models missing a type (Codex has no cache measurements), so this tracks context_tokens, present on every record.",
      "type": "timeseries",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 55,
            "lineWidth": 0,
            "stacking": {
              "mode": "normal"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "sum"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "legendFormat": "{{workbench_attribute_model}}",
          "expr": "sum by (workbench_attribute_model) (sum_over_time({service_name=\"workbench-observer\"} |= \"gateway.token.usage\" | workbench_session_id !~ \"(probe|session-gateway).*\" | unwrap workbench_measurement_context_tokens_value [$__auto]))"
        }
      ],
      "maxDataPoints": 60
    },
    {
      "id": 7,
      "title": "Cost over time",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "legendFormat": "{{project_id}}",
          "expr": "sum by (project_id) (increase(claude_code_cost_usage_USD_total{project_id=~\"$project\"}[$__rate_interval]))"
        }
      ]
    },
    {
      "id": 8,
      "title": "Usage by project",
      "type": "table",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "options": {
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Cost"
            },
            "properties": [
              {
                "id": "unit",
                "value": "currencyUSD"
              },
              {
                "id": "decimals",
                "value": 2
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "instant": true,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (project_id) (increase(claude_code_token_usage_tokens_total{project_id=~\"$project\"}[$__range]))"
        },
        {
          "refId": "B",
          "format": "table",
          "instant": true,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (project_id) (increase(claude_code_cost_usage_USD_total{project_id=~\"$project\"}[$__range]))"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "project_id": "Project",
              "Value #A": "Tokens",
              "Value #B": "Cost"
            }
          }
        }
      ]
    },
    {
      "id": 9,
      "title": "Models in use",
      "description": "Full input context volume (fresh input + cache) by resolved gateway model over the selected range. Output tokens excluded.",
      "type": "bargauge",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "valueMode": "text",
        "reduceOptions": {
          "values": true,
          "calcs": [],
          "limit": 25
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          },
          "min": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "instant",
          "instant": true,
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "legendFormat": "{{workbench_attribute_model}}",
          "expr": "sum by (workbench_attribute_model) (sum_over_time({service_name=\"workbench-observer\"} |= \"gateway.token.usage\" | workbench_session_id !~ \"(probe|session-gateway).*\" | unwrap workbench_measurement_context_tokens_value [$__range]))"
        }
      ]
    },
    {
      "id": 10,
      "title": "Token volume by backend",
      "description": "Full input context volume by resolved backend from gateway records: anthropic (Claude subscription) vs codex (ChatGPT subscription). Output tokens excluded.",
      "type": "bargauge",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 26
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "valueMode": "text",
        "reduceOptions": {
          "values": true,
          "calcs": [],
          "limit": 25
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "continuous-GrYlRd"
          },
          "min": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "instant",
          "instant": true,
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "legendFormat": "{{workbench_attribute_backend}}",
          "expr": "sum by (workbench_attribute_backend) (sum_over_time({service_name=\"workbench-observer\"} |= \"gateway.token.usage\" | workbench_session_id !~ \"(probe|session-gateway).*\" | unwrap workbench_measurement_context_tokens_value [$__range]))"
        }
      ]
    },
    {
      "id": 11,
      "title": "Tool activity by name",
      "description": "Estimated result tokens by tool. A tool result re-enters the LLM as input on later requests, usually at cache-read rates after its first inclusion, so large results tax every turn until compaction. Call count stays visible for frequency.",
      "type": "table",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 26
      },
      "options": {
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "queryType": "instant",
          "instant": true,
          "expr": "sum by (workbench_attribute_tool_name) (sum_over_time({service_name=\"workbench-observer\"} |= \"hook.post_tool_use\" | unwrap workbench_measurement_tool_result_tokens_estimate_value [$__range]))",
          "legendFormat": "{{workbench_attribute_tool_name}}"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "queryType": "instant",
          "instant": true,
          "expr": "sum by (workbench_attribute_tool_name) (count_over_time({service_name=\"workbench-observer\"} |= \"hook.post_tool_use\" [$__range]))",
          "legendFormat": "{{workbench_attribute_tool_name}}"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "renameByName": {
              "workbench_attribute_tool_name": "Tool",
              "Value #A": "Result tokens (estimate)",
              "Value #B": "Calls"
            }
          }
        }
      ]
    },
    {
      "id": 12,
      "title": "MCP activity by server / tool",
      "description": "MCP server rollup for estimated tool-result tokens and calls. Tool results re-enter the LLM as input on later requests. The adjacent definition table shows the per-request input cost of each server’s tool definitions; per-tool detail is directly beneath.",
      "type": "table",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 86
      },
      "options": {
        "showHeader": true,
        "footer": {
          "show": true,
          "reducer": [
            "sum"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "queryType": "instant",
          "instant": true,
          "expr": "sum by (workbench_attribute_mcp_server) (sum_over_time({service_name=\"workbench-observer\"} |= \"hook.post_tool_use\" | workbench_attribute_is_mcp = \"true\" | workbench_session_id !~ \"(probe|session-gateway).*\" | workbench_session_id !~ \"(probe|session-gateway).*\" | workbench_session_id !~ \"(probe|session-gateway).*\" | workbench_session_id !~ \"(probe|session-gateway).*\" | unwrap workbench_measurement_tool_result_tokens_estimate_value [$__range]))",
          "legendFormat": "{{workbench_attribute_mcp_server}}"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "queryType": "instant",
          "instant": true,
          "expr": "sum by (workbench_attribute_mcp_server) (count_over_time({service_name=\"workbench-observer\"} |= \"hook.post_tool_use\" | workbench_attribute_is_mcp = \"true\" | workbench_session_id !~ \"(probe|session-gateway).*\" | workbench_session_id !~ \"(probe|session-gateway).*\" | workbench_session_id !~ \"(probe|session-gateway).*\" | workbench_session_id !~ \"(probe|session-gateway).*\" [$__range]))",
          "legendFormat": "{{workbench_attribute_mcp_server}}"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "renameByName": {
              "workbench_attribute_mcp_server": "MCP server",
              "Value #A": "Result tokens (estimate)",
              "Value #B": "Calls"
            }
          }
        }
      ]
    },
    {
      "id": 13,
      "title": "Tool activity error rate",
      "description": "Share of completed tool activity carrying an error status. This is frequency, not token cost.",
      "type": "stat",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 34
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 2
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "queryType": "instant",
          "instant": true,
          "expr": "(100 * sum(count_over_time({service_name=\"workbench-observer\"} |= \"hook.post_tool_use\" | workbench_attribute_status =~ \"error|failed\" [$__range])) / sum(count_over_time({service_name=\"workbench-observer\"} |= \"hook.post_tool_use\" [$__range]))) or vector(0)"
        }
      ]
    },
    {
      "id": 14,
      "title": "Tool activity duration p95",
      "description": "Observed hook duration when the hook payload supplies it. Missing durations stay unavailable.",
      "type": "stat",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 34
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "queryType": "instant",
          "instant": true,
          "expr": "quantile_over_time(0.95, {service_name=\"workbench-observer\"} |= \"hook.post_tool_use\" | unwrap workbench_measurement_duration_ms_value [$__range])"
        }
      ]
    },
    {
      "id": 15,
      "title": "Active vs idle time",
      "description": "Claude Code active-time telemetry, grouped by the provider activity type.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 38
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "stacking": {
              "mode": "normal"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "sum"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "legendFormat": "{{type}}",
          "expr": "sum by (type) (increase(claude_code_active_time_seconds_total{project_id=~\"$project\"}[$__rate_interval]))"
        }
      ]
    },
    {
      "id": 16,
      "title": "MCP connection activity",
      "description": "Connection attempts and failures by MCP server. This is reliability activity, not token attribution.",
      "type": "timeseries",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 42
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 45,
            "stacking": {
              "mode": "normal"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "sum"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum by (workbench_attribute_mcp_server, workbench_attribute_status) (count_over_time({service_name=\"workbench-observer\"} |= \"claude_code.mcp_server_connection\" [$__auto])) or vector(0)",
          "legendFormat": "{{workbench_attribute_mcp_server}} / {{workbench_attribute_status}}"
        }
      ]
    },
    {
      "id": 17,
      "title": "Hook execution activity / failures",
      "description": "Own-hook completion frequency by hook name and provider status. Hook duration stays unavailable when Claude Code omits it from this event.",
      "type": "timeseries",
