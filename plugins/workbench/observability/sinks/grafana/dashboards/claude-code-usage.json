{
  "uid": "claude-code-usage",
  "title": "Claude Code Usage",
  "tags": ["claude-code", "workbench", "tokens"],
  "timezone": "browser",
  "schemaVersion": 39,
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "project",
        "label": "Project",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": { "query": "label_values(claude_code_token_usage_tokens_total, project_id)", "refId": "project" },
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Total tokens",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area", "textMode": "value" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(increase(claude_code_token_usage_tokens_total{project_id=~\"$project\"}[$__range]))" }
      ]
    },
    {
      "id": 2,
      "title": "Input tokens",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area", "textMode": "value" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(increase(claude_code_token_usage_tokens_total{type=\"input\",project_id=~\"$project\"}[$__range]))" }
      ]
    },
    {
      "id": 3,
      "title": "Output tokens",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area", "textMode": "value" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "purple" } }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(increase(claude_code_token_usage_tokens_total{type=\"output\",project_id=~\"$project\"}[$__range]))" }
      ]
    },
    {
      "id": 4,
      "title": "Cost (USD)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area", "textMode": "value" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 2, "color": { "mode": "fixed", "fixedColor": "orange" } }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(increase(claude_code_cost_usage_USD_total{project_id=~\"$project\"}[$__range]))" }
      ]
    },
    {
      "id": 5,
      "title": "Tokens over time, by type",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 20, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "legendFormat": "{{type}}", "expr": "sum by (type) (increase(claude_code_token_usage_tokens_total{project_id=~\"$project\"}[$__rate_interval]))" }
      ]
    },
    {
      "id": 6,
      "title": "Tokens over time, by model",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 20, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "legendFormat": "{{model}}", "expr": "sum by (model) (increase(claude_code_token_usage_tokens_total{project_id=~\"$project\"}[$__rate_interval]))" }
      ]
    },
    {
      "id": 7,
      "title": "Cost over time",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "custom": { "drawStyle": "bars", "fillOpacity": 60 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "legendFormat": "{{project_id}}", "expr": "sum by (project_id) (increase(claude_code_cost_usage_USD_total{project_id=~\"$project\"}[$__rate_interval]))" }
      ]
    },
    {
      "id": 8,
      "title": "Usage by project",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "options": { "showHeader": true },
      "fieldConfig": { "defaults": {}, "overrides": [ { "matcher": { "id": "byName", "options": "Cost" }, "properties": [ { "id": "unit", "value": "currencyUSD" }, { "id": "decimals", "value": 2 } ] } ] },
      "targets": [
        { "refId": "A", "format": "table", "instant": true, "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (project_id) (increase(claude_code_token_usage_tokens_total{project_id=~\"$project\"}[$__range]))" },
        { "refId": "B", "format": "table", "instant": true, "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (project_id) (increase(claude_code_cost_usage_USD_total{project_id=~\"$project\"}[$__range]))" }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        { "id": "organize", "options": { "renameByName": { "project_id": "Project", "Value #A": "Tokens", "Value #B": "Cost" } } }
      ]
    },
    {
      "id": 9,
      "title": "Models in use (last 5m)",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 20 },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true, "valueMode": "text", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "legendFormat": "{{model}}", "expr": "sum by (model) (increase(claude_code_token_usage_tokens_total{project_id=~\"$project\"}[5m]))" }
      ]
    },
    {"id":10,"title":"Token volume by provider / backend","description":"Exact token telemetry grouped by provider and backend.","type":"bargauge","datasource":{"type":"prometheus","uid":"prometheus"},"gridPos":{"h":7,"w":12,"x":0,"y":26},"options":{"orientation":"horizontal","displayMode":"gradient","showUnfilled":true,"valueMode":"text","reduceOptions":{"calcs":["lastNotNull"]}},"fieldConfig":{"defaults":{"unit":"short","color":{"mode":"continuous-GrYlRd"}},"overrides":[]},"targets":[{"refId":"A","datasource":{"type":"prometheus","uid":"prometheus"},"legendFormat":"{{provider}} / {{backend}}","expr":"sum by (provider, backend) (increase(claude_code_token_usage_tokens_total{project_id=~\"$project\"}[$__range]))"}]},
    {"id":11,"title":"Tool activity by name","description":"Call frequency from hook activity. This panel does not attribute token cost to tools.","type":"table","datasource":{"type":"loki","uid":"loki"},"gridPos":{"h":8,"w":12,"x":12,"y":26},"options":{"showHeader":true},"fieldConfig":{"defaults":{"unit":"short"},"overrides":[]},"targets":[{"refId":"A","datasource":{"type":"loki","uid":"loki"},"queryType":"instant","instant":true,"expr":"sum by (workbench_attribute_tool_name) (count_over_time({service_name=\"workbench-observer\"} |= \"hook.post_tool_use\" [$__range]))","legendFormat":"{{workbench_attribute_tool_name}}"}]},
    {"id":12,"title":"MCP activity by server / tool","description":"MCP call frequency only. Per-call and per-MCP token attribution is unavailable.","type":"bargauge","datasource":{"type":"loki","uid":"loki"},"gridPos":{"h":8,"w":12,"x":0,"y":34},"options":{"orientation":"horizontal","displayMode":"basic","showUnfilled":false,"valueMode":"text","reduceOptions":{"calcs":["lastNotNull"]}},"fieldConfig":{"defaults":{"unit":"short","color":{"mode":"continuous-BlPu"}},"overrides":[]},"targets":[{"refId":"A","datasource":{"type":"loki","uid":"loki"},"queryType":"instant","instant":true,"expr":"sum by (workbench_attribute_mcp_server, workbench_attribute_mcp_tool) (count_over_time({service_name=\"workbench-observer\"} |= \"hook.post_tool_use\" | workbench_attribute_is_mcp=\"true\" [$__range]))","legendFormat":"{{workbench_attribute_mcp_server}} / {{workbench_attribute_mcp_tool}}"}]},
    {"id":13,"title":"Tool activity error rate","description":"Share of completed tool activity carrying an error status. This is frequency, not token cost.","type":"stat","datasource":{"type":"loki","uid":"loki"},"gridPos":{"h":4,"w":6,"x":12,"y":34},"options":{"reduceOptions":{"calcs":["lastNotNull"]},"colorMode":"value","graphMode":"none","textMode":"value"},"fieldConfig":{"defaults":{"unit":"percent","decimals":1,"thresholds":{"mode":"absolute","steps":[{"color":"green","value":null},{"color":"orange","value":2},{"color":"red","value":10}]}},"overrides":[]},"targets":[{"refId":"A","datasource":{"type":"loki","uid":"loki"},"queryType":"instant","instant":true,"expr":"100 * sum(count_over_time({service_name=\"workbench-observer\"} |= \"hook.post_tool_use\" | workbench_attribute_status=~\"error|failed\" [$__range])) / clamp_min(sum(count_over_time({service_name=\"workbench-observer\"} |= \"hook.post_tool_use\" [$__range])), 1)"}]},
    {"id":14,"title":"Tool activity duration p95","description":"Observed hook duration when the hook payload supplies it. Missing durations stay unavailable.","type":"stat","datasource":{"type":"loki","uid":"loki"},"gridPos":{"h":4,"w":6,"x":18,"y":34},"options":{"reduceOptions":{"calcs":["lastNotNull"]},"colorMode":"value","graphMode":"area","textMode":"value"},"fieldConfig":{"defaults":{"unit":"ms","decimals":0,"color":{"mode":"fixed","fixedColor":"blue"}},"overrides":[]},"targets":[{"refId":"A","datasource":{"type":"loki","uid":"loki"},"queryType":"instant","instant":true,"expr":"quantile_over_time(0.95, {service_name=\"workbench-observer\"} |= \"hook.post_tool_use\" | unwrap workbench_measurement_duration_ms_value [$__range])"}]},
    {"id":15,"title":"Active vs idle time","description":"Claude Code active-time telemetry, grouped by the provider activity type.","type":"timeseries","datasource":{"type":"prometheus","uid":"prometheus"},"gridPos":{"h":8,"w":12,"x":12,"y":38},"fieldConfig":{"defaults":{"unit":"s","custom":{"drawStyle":"line","fillOpacity":20,"stacking":{"mode":"normal"}}},"overrides":[]},"options":{"legend":{"displayMode":"table","placement":"bottom","calcs":["sum"]},"tooltip":{"mode":"multi"}},"targets":[{"refId":"A","datasource":{"type":"prometheus","uid":"prometheus"},"legendFormat":"{{type}}","expr":"sum by (type) (increase(claude_code_active_time_seconds_total{project_id=~\"$project\"}[$__rate_interval]))"}]},
    {"id":16,"title":"MCP connection activity","description":"Connection attempts and failures by MCP server. This is reliability activity, not token attribution.","type":"timeseries","datasource":{"type":"loki","uid":"loki"},"gridPos":{"h":8,"w":12,"x":0,"y":42},"fieldConfig":{"defaults":{"unit":"short","custom":{"drawStyle":"bars","fillOpacity":45,"stacking":{"mode":"normal"}}},"overrides":[]},"options":{"legend":{"displayMode":"table","placement":"bottom","calcs":["sum"]},"tooltip":{"mode":"multi"}},"targets":[{"refId":"A","datasource":{"type":"loki","uid":"loki"},"expr":"sum by (server_name, status) (count_over_time({service_name=~\".+\"} |= \"mcp_server_connection\" [$__rate_interval]))","legendFormat":"{{server_name}} / {{status}}"}]},
    {"id":17,"title":"Hook execution overhead / failures","description":"Own-hook execution duration and failure activity from Claude Code telemetry.","type":"timeseries","datasource":{"type":"loki","uid":"loki"},"gridPos":{"h":8,"w":12,"x":12,"y":46},"fieldConfig":{"defaults":{"unit":"ms","custom":{"drawStyle":"line","fillOpacity":10}},"overrides":[]},"options":{"legend":{"displayMode":"table","placement":"bottom","calcs":["mean","max"]},"tooltip":{"mode":"multi"}},"targets":[{"refId":"A","datasource":{"type":"loki","uid":"loki"},"expr":"avg by (hook_name, status) (avg_over_time({service_name=~\".+\"} |= \"hook_execution_complete\" | unwrap duration_ms [$__rate_interval]))","legendFormat":"{{hook_name}} / {{status}}"}]},
    {"id":18,"title":"Subagent lifecycle activity","description":"Starts and stops by agent type. Counts lifecycle activity, not tokens.","type":"timeseries","datasource":{"type":"loki","uid":"loki"},"gridPos":{"h":8,"w":12,"x":0,"y":50},"fieldConfig":{"defaults":{"unit":"short","custom":{"drawStyle":"bars","fillOpacity":45,"stacking":{"mode":"normal"}}},"overrides":[]},"options":{"legend":{"displayMode":"table","placement":"bottom","calcs":["sum"]},"tooltip":{"mode":"multi"}},"targets":[{"refId":"A","datasource":{"type":"loki","uid":"loki"},"expr":"sum by (workbench_attribute_agent_type) (count_over_time({service_name=\"workbench-observer\"} |~ \"hook.subagent_(start|stop)\" [$__rate_interval]))","legendFormat":"{{workbench_attribute_agent_type}}"}]}
  ]
}
