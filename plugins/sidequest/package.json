{
  "name": "@eigenwise/sidequest",
  "private": true,
  "type": "commonjs",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "node scripts/build.mjs",
    "build:check": "npm run build && git diff --exit-code -- bin lib hooks",
    "drift": "npm run build && node scripts/drift.mjs",
    "test:files": "node --import tsx --test",
    "test:full": "npm run typecheck && npm run build:check && node scripts/test-full.mjs",
    "test:perf": "node --import tsx --test test/*.perf.test.ts"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "esbuild": "0.28.1",
    "tsx": "4.23.1",
    "typescript": "7.0.2"
  }
}
